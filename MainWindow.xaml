<Window x:Class="Aragon101.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Aragon101"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="5"/>
            <ColumnDefinition Width="2*" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="5" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="5"/>
            <RowDefinition Height="40"/>
            <RowDefinition Height="5"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="5"/>
        </Grid.RowDefinitions>

        <!--#region TITLE-->
        <Label Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2"
               FontStyle="Normal" FontWeight="Bold"
               HorizontalContentAlignment="Center"
               FontSize="26"
               Content="PRODUCT LIST" FontFamily="Adobe Caslon Pro Bold" Background="#FF80DEEA"/>
        <Separator Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2" />
        <!--#endregion-->

        <!--#region STUDENT TABLE-->
        <StackPanel Grid.Row="3" Grid.Column="1"
                    Orientation="Vertical"
                    x:Name="panelStudentTable" Background="#FF80DEEA">
            <DataGrid x:Name="dataGrid" Height="292"
                      AutoGenerateColumns="False"
                      SelectionChanged="dataGrid_SelectionChanged"
                      FontSize="13" Width="526" Background="#FFE0F7FA" FontFamily="Segoe UI Variable Display Semibold">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Store Name      "
                            Binding="{Binding StoreName}" />
                    <DataGridTextColumn Header="Product Name                              "
                            Binding="{Binding Product}" />
                    <DataGridTextColumn Header="Klg.            "
                            Binding="{Binding Quantity}" />
                    <DataGridTextColumn Header="Price      "
                            Binding="{Binding Price}" />
                    <DataGridTextColumn Header="Total      "
                            Binding="{Binding Total}" />
                </DataGrid.Columns>
            </DataGrid>
            <Button x:Name="btnDeleteData" Content="DELETE DATA"
                    Height="54" FontSize="20"
                    FontWeight="Bold"
                    Margin="0,5"
                    IsEnabled="False"
                    Click="btnDeleteData_Click"
                    Background="#FF4DD0E1" Width="400"
                    />
        </StackPanel>
        <!--#endregion-->

        <!--#region STUDENT TABLE-->
        <Grid Grid.Row="3" Grid.Column="2" Background="#FFB2EBF2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition/>
                <ColumnDefinition Width="10"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="30"/>
                <RowDefinition Height="10"/>
                <RowDefinition Height="20"/>
                <RowDefinition Height="30"/>
                <RowDefinition Height="10"/>
                <RowDefinition Height="20"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="10"/>
                <RowDefinition Height="20"/>
                <RowDefinition Height="30"/>
                <RowDefinition Height="10"/>
                <RowDefinition Height="20"/>
                <RowDefinition Height="30"/>
                <RowDefinition Height="50"/>
                <RowDefinition/>
            </Grid.RowDefinitions>
            <!--Form Title-->
            <Label Grid.Row="0"
                   Grid.Column="1"                                      Content="Product Details"
                   FontWeight="DemiBold"
                   HorizontalContentAlignment="Center"
                   VerticalContentAlignment="Center"
                   FontSize="13" FontFamily="Segoe UI Variable Display Semibold" />
            <Label Grid.Row="2"
                   Grid.Column="1"
                   Content="Store Name"
                   FontSize="11"
                   Padding="1"
                   FontWeight="DemiBold" Margin="10,0,0,0" FontFamily="Segoe UI Variable Display Semibold" />
            <Label Grid.Row="9"
                   Grid.Column="1"
                   Content="Price"
                   FontSize="11"
                   Padding="1"
                   FontWeight="DemiBold" Margin="10,10,0,0" FontFamily="Segoe UI Variable Display Semibold" />
            <TextBox Grid.Row="3"
                     x:Name="txtStoreName"
                     Grid.Column="1" 
                     HorizontalContentAlignment="Left"
                     FontSize="14"
                     BorderThickness="0,0,0,1"
                     Padding="2" Background="#FFE0F7FA" Margin="10,0,0,0" />
            <TextBox Grid.Row="10"
                    x:Name="txtPrice"
                    Grid.Column="1" 
                    HorizontalContentAlignment="Left"
                    FontSize="14"
                    BorderThickness="0,0,0,1"
                    Padding="2" Background="#FFE0F7FA" Margin="10,0,0,0" Grid.RowSpan="2" Height="30" VerticalAlignment="Top" />
            <Label Grid.Row="5"
                   Grid.Column="1"
                   Content="Product"
                   FontSize="11"
                   Padding="1"
                   FontWeight="DemiBold" Margin="10,0,5,5" FontFamily="Segoe UI Variable Display Semibold" Grid.ColumnSpan="2" />
            <Label Grid.Row="12"
                  Grid.Column="1"
                  Content="Quantity"
                  FontSize="11"
                  Padding="1"
                  FontWeight="DemiBold" Margin="10,10,5,5" FontFamily="Segoe UI Variable Display Semibold" Grid.ColumnSpan="2" />

            <ComboBox x:Name="comboBoxProduct"
                      Grid.Row="7"
                      Grid.Column="1"
                      BorderThickness="0" Margin="10,0,0,0" Grid.RowSpan="2">
                <ComboBox.Background>
                    <LinearGradientBrush EndPoint="0,1">
                        <GradientStop Color="#FFF0F0F0"/>
                        <GradientStop Color="#FFE0F7FA" Offset="1"/>
                    </LinearGradientBrush>
                </ComboBox.Background>
                <ComboBoxItem Content="Siomai"/>
                <ComboBoxItem Content="Chicken Siomai"/>
                <ComboBoxItem Content="Beef Siomai"/>
                <ComboBoxItem Content="Chicken Toccino "/>
                <ComboBoxItem Content="Pork Toccino"/>
                <ComboBoxItem Content="Hotdog"/>
                <ComboBoxItem Content="Ham"/>
                <ComboBoxItem Content="Torikatsu"/>
                <ComboBoxItem Content="Tongkatsu"/>
            </ComboBox>
            <ComboBox x:Name="comboBoxQuantity"
           Grid.Row="13"
           Grid.Column="1"
           BorderThickness="0" Background="#FFE0F7FA" Margin="10,0,0,25">
                <ComboBoxItem Content="250mg"/>
                <ComboBoxItem Content="500mg"/>
                <ComboBoxItem Content="750mg"/>
                <ComboBoxItem Content="1000mg"/>

            </ComboBox>
            <Button x:Name="btnSave" 
                    Grid.Column="1" Grid.Row="14"
                    Content="SAVE" FontSize="20"
                    Click="btnSave_Click"
                    Margin="31,0,21,24" FontWeight="Bold" FontFamily="Adobe Caslon Pro Bold" Background="#FF80DEEA"/>

        </Grid>
    </Grid>
</Window>
